extends layout

block content
  if(sliders)
    #homeCarouselControls.carousel.slide(data-ride='carousel')
      .carousel-inner
        each slider, i in sliders
          if(i===0)
            .carousel-item.active.slider-containter
              .description.text-light
                !=slider.description
              .home_slider.d-block.w-100(style=`background:url(${slider.photo})`)
          else   
            .carousel-item.slider-containter
              .description.text-light
                 !=slider.description
              .home_slider.d-block.w-100(style=`background:url(${slider.photo})`)
      a.carousel-control-prev(href='#homeCarouselControls' role='button' data-slide='prev')
        span.carousel-control-prev-icon(aria-hidden='true')
        span.sr-only Previous
      a.carousel-control-next(href='#homeCarouselControls' role='button' data-slide='next')
        span.carousel-control-next-icon(aria-hidden='true')
        span.sr-only Next
  .section
    .d-flex.justify-content-center.p-3
      .px-4.text-white.font-weight-bold.text-center
        h2.p-0.m-0 #{location}
        p.p-0.m-0 LOCATIONS
      .px-4.text-white.font-weight-bold.text-center
        h2.p-0.m-0 100
        p.p-0.m-0 SKILLS
      .px-4.text-white.font-weight-bold.text-center
        h2.p-0.m-0 500
        p.p-0.m-0 TALENTS
      .px-4.text-white.font-weight-bold.text-center
        h2.p-0.m-0 #{engagement}
        p.p-0.m-0 ENGAGEMENTS
  //Skills and Talent section
  .container.px-4
    .d-flex.justify-content-center
    if(items)
        #skill-carousel.carousel.slide(data-ride='carousel')
          .carousel-inner
            if(items.first)
                .carousel-item.active.skill-containter(data-interval="10000")
                  .row
                    each item, i in items.first
                      .col.col-sm.col-md.d-flex.align-items-center.justify-content-center(style=`background-image:url(${item.photo})`)   
            if(items.second)
                .carousel-item.skill-containter(data-interval="10000")
                  .row
                    each item, i in items.second
                        .col.col-sm.col-md.d-flex.align-items-center.justify-content-center(style=`background-image:url(${item.photo})`)  
            if(items.third)
                .carousel-item.skill-containter(data-interval="10000")
                  .row
                    each item, i in items.third
                        .col.col-sm.col-md.d-flex.align-items-center.justify-content-center(style=`background-image:url(${item.photo})`) 
            if(items.fourth)
                .carousel-item.skill-containter(data-interval="10000")
                  .row
                    each item, i in items.fourth
                        .col.col-sm.col-md.d-flex.align-items-center.justify-content-center(style=`background-image:url(${item.photo})`) 
 
          a.carousel-control-prev(href='#skill-carousel' role='button' data-slide='prev')
            span.carousel-control-prev-icon(aria-hidden='true')
            span.sr-only Previous
          a.carousel-control-next(href='#skill-carousel' role='button' data-slide='next')
            span.carousel-control-next-icon(aria-hidden='true')
            span.sr-only Next
  //Nigeria's displacement statistics
  .displacement_statistics
    #map
  //Story section 
  .container.py-5.story
    .d-flex.justify-content-center.py-3
      h2.font-weight-bold.border-bottom.border-white OUR STORIES
    .row
      if(stories)
        each story, i in stories
          .col-sm-6.col-md-4.pt-4
            .card.mb-3.bg-transparent.border-0(style='max-width: 500px;')
              .row.no-gutters
                .col-md-5
                  .h-100
                    a(href=`${story._id}`)
                     img.card-img.img-fluid(src=`${story.photo}` alt=`${story.title}`)
                .col-md-7
                  .card-body.py-0.px-1
                    a(href=`${story._id}`)
                      span.text-white.font-weight-bold.card-title.mb-0 #{story.title}
                    p.card-text
                      small.text-muted #{story.description}


  //Partner section  
  .section
    .container.p-4
      .d-flex.justify-content-center.py-3
       h2.font-weight-bold.border-bottom.border-white.text-white PARTNERS
      if(partners)
          #partner-carousel.carousel.slide(data-ride='carousel')
            .carousel-inner.row.w-100.mx-auto(role='listbox')
              each partner, i in partners
                if(i===0)
                  .carousel-item.col-12.col-sm-6.col-md-4.col-lg-3.active.partner-containter
                    img.img-fluid.mx-auto.d-block(src=`${partner.photo}` alt=`${partner.name}`)
                else   
                  .carousel-item.col-12.col-sm-6.col-md-4.col-lg-3.partner-containter
                    img.img-fluid.mx-auto.d-block(src=`${partner.photo}` alt=`${partner.name}`)
            a.carousel-control-prev(href='#partner-carousel' role='button' data-slide='prev')
              span.carousel-control-prev-icon(aria-hidden='true')
              span.sr-only Previous
            a.carousel-control-next(href='#partner-carousel' role='button' data-slide='next')
              span.carousel-control-next-icon(aria-hidden='true')
              span.sr-only Next
      
      
    
