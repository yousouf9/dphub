doctype html
html(lang="en")
  head
    meta(charset='utf-8')
    meta(name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no")
    title= title
    link(href='https://fonts.googleapis.com/css2?family=Roboto:wght@100;300;400;500&display=swap' rel='stylesheet')
    //Bootstrap CSS
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/css/bootstrap.min.css', integrity='sha384-TX8t27EcRE3e/ihU7zmQxVncDAy5uIKz4rEkgIXeMed4M0jlfIDPvg6uqKI2xXr2', crossorigin='anonymous')

    //Custom styling
    link(rel='stylesheet', href='/stylesheets/style.css')
    //Fonts awesomes
    script(src='https://use.fontawesome.com/b5c31f66c4.js')
    script(src='https://kit.fontawesome.com/618b4b277c.js' crossorigin='anonymous')

  
    
  body
    .container-fluid
        p.text-mutted LOGO
    nav.navbar.navbar-expand-lg.navbar-light.section.px-3.py-0
      a.navbar-brand(href='') 
      button.navbar-toggler(type='button', data-toggle='collapse', data-target='#navbarSupportedContent', aria-controls='navbarSupportedContent', aria-expanded='false', aria-label='Toggle navigation')
        span.navbar-toggler-icon
      #navbarSupportedContent.collapse.navbar-collapse
        ul.navbar-nav.mr-auto
          li.nav-item
            a.nav-link(href='/' class=`${title === 'Home'? 'active' : '' }`)
              | HOME
              span.sr-only (current)
          li.nav-item.dropdown
            a#navbarDropdown.nav-link.dropdown-toggle(href='#',  class=`${title === 'About'? 'active' : '' }` role='button', data-toggle='dropdown', aria-haspopup='true', aria-expanded='false')
              | ABOUT US
            .dropdown-menu(aria-labelledby='navbarDropdown')
              a.dropdown-item(href='/about/whoweare' class=`${title === 'About'? 'active' : '' }`) WHO WE ARE
              a.dropdown-item(href='/about/whyweexist' class=`${title === 'About'? 'active' : '' }`) WHY WE EXIST
              a.dropdown-item(href='/about/team' class=`${title === 'About'? 'active' : '' }`) TEAM
          li.nav-item.dropdown
            a#navbarDropdown.nav-link.dropdown-toggle(href='#',  class=`${title === 'WhatWeDo'? 'active' : '' }` role='button', data-toggle='dropdown', aria-haspopup='true', aria-expanded='false')
              | WHAT WE DO
            .dropdown-menu(aria-labelledby='navbarDropdown')
              a.dropdown-item(href='#') SKILLS PROFILING
              a.dropdown-item(href='#') TALENTS PROFILING
              a.dropdown-item(href='#') DP COMPLAIN
              a.dropdown-item(href='#') DISPLACEMENT MONITOR
          li.nav-item
            a.nav-link(href='/getinvolved' class=`${title === 'GetInvolved'? 'active' : '' }`)
              | GET INVOLVED
          li.nav-item.dropdown
            a#navbarDropdown.nav-link.dropdown-toggle(href='#', class=`${title === 'Resources'? 'active' : '' }` role='button', data-toggle='dropdown', aria-haspopup='true', aria-expanded='false')
              | RESOURCES
            .dropdown-menu(aria-labelledby='navbarDropdown')
              a.dropdown-item(href='#') PRESS RELEASES
              a.dropdown-item(href='#') REPORT
              a.dropdown-item(href='#') BLOG
          li.nav-item
            a.nav-link(href='#' class=`${title === 'Contact'? 'active' : '' }`)
              | CONTACT

        ul.my-2.my-lg-0
          li.nav-item(style="list-style:none")
            a.nav-link(href='/donate' class=`donate`)
              | Donate

    block content
    //!= messages()
    footer
      .d-flex.bd-highlight.text-white
        .p-2.flex-grow-1.bd-highlight.pl-5  © DISPLACED PERSONS HUB
        .p-2.bd-highlight.pr-5
          .bg-dark.p-1
            i.fab.fa-google-plus-g
            i.fab.fa-twitter
            i.fab.fa-instagram
            i.fab.fa-facebook-f
    script(src='https://code.jquery.com/jquery-3.5.1.slim.min.js', integrity='sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVBnE+IbbVYUew+OrCXaRkfj', crossorigin='anonymous')
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/js/bootstrap.bundle.min.js', integrity='sha384-ho+j7jyWK8fNQe+A12Hb8AhRq26LrZ/JpcUGGOn+Y7RsweNrtN/tE3MoK7ZeZDyx', crossorigin='anonymous')
    script(src='/javascripts/main.js')