doctype html
html
  head
    title= title

    //Bootstrap CSS
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/css/bootstrap.min.css', integrity='sha384-TX8t27EcRE3e/ihU7zmQxVncDAy5uIKz4rEkgIXeMed4M0jlfIDPvg6uqKI2xXr2', crossorigin='anonymous')
    link(rel='stylesheet', href='/stylesheets/style.css')
    //Fonts awesomes
    script(src='https://use.fontawesome.com/b5c31f66c4.js')
    script(src='https://kit.fontawesome.com/618b4b277c.js' crossorigin='anonymous')
  body
    .container-fluid.login
        .p-0.m-0.h-100.d-flex.justify-content-center.align-items-center
        
            .shadow.p-5.bg-white.roundeda
                form(method='post', action='/users/login')
                        .input-group.mb-3
                            .input-group-prepend
                                .input-group-text @
                            input.form-control(type="text" name="username" placeholder="Username" required)
                            
                        .input-group.mb-3
                            .input-group-prepend
                                .input-group-text 
                                    i.fas.fa-key
                            input.form-control(type="password" name="password" placeholder="password" required)
                        .d-flex
                            .p-2 
                                .custom-control.custom-checkbox
                                    input#customCheck1.custom-control-input(type='checkbox')
                                    label.custom-control-label.pt-1(for='customCheck1') Remember me
                            .ml-auto.p-2
                                a.nav-link(href="#") Forgot password
                        input.btn.btn-block.btn-success.mb-3(name="submit" type="submit" value="Login")
        